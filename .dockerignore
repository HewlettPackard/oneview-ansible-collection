# Ignore EVERYTHING first
**

# Allow only what Docker actually needs
!Dockerfile
!.dockerignore
!requirements.txt
!ansible.cfg
!galaxy.yml

!roles/**
!playbooks/**
!plugins/**
!sdkAutomator/**
!auto_config.json

# Explicit junk exclusions (inside allowed dirs)
**/__pycache__/
**/*.pyc
**/*.log
**/*.tmp
**/.git
**/.gitignore
tests/
docs/
firmware/
*.tar.gz
*.zip
*.md
